// Prisma-схема — единый источник структуры БД.
// Таблицы соответствуют docs/02-ARCHITECTURE.md §Модель данных.
// Enum'ы синхронны с packages/shared/src/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  admin
  client
}

enum UserStatus {
  active
  blocked
}

enum DocumentType {
  pdf
  docx
  xlsx
}

enum DocumentStatus {
  queued
  processing
  ready
  failed
}

enum MessageRole {
  user
  assistant
}

enum Confidence {
  high
  low
  refused
}

// ─────────────────────────── Модели ───────────────────────────

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         Role       @default(client)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")

  chats            Chat[]
  createdDocuments Document[] @relation("DocumentCreatedBy")
  auditLogs        AuditLog[]

  @@map("users")
}

model Document {
  id            String         @id @default(uuid()) @db.Uuid
  title         String
  type          DocumentType
  s3Key         String         @map("s3_key")
  status        DocumentStatus @default(queued)
  version       Int            @default(1)
  // Задел под v2 (группы доступа) — в v1 всегда null (см. CLAUDE.md).
  accessGroupId String?        @map("access_group_id") @db.Uuid
  pages         Int?
  chunkCount    Int?           @map("chunk_count")
  errorMessage  String?        @map("error_message")
  indexedAt     DateTime?      @map("indexed_at")
  createdBy     String         @map("created_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")

  creator  User            @relation("DocumentCreatedBy", fields: [createdBy], references: [id])
  sources  MessageSource[]

  @@index([status])
  @@index([accessGroupId])
  @@map("documents")
}

model Chat {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  createdAt DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("chats")
}

model Message {
  id         String      @id @default(uuid()) @db.Uuid
  chatId     String      @map("chat_id") @db.Uuid
  role       MessageRole
  content    String
  confidence Confidence?
  tokensIn   Int?        @map("tokens_in")
  tokensOut  Int?        @map("tokens_out")
  cached     Boolean     @default(false)
  createdAt  DateTime    @default(now()) @map("created_at")

  chat    Chat            @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sources MessageSource[]

  @@index([chatId])
  @@map("messages")
}

model MessageSource {
  id         String  @id @default(uuid()) @db.Uuid
  messageId  String  @map("message_id") @db.Uuid
  documentId String  @map("document_id") @db.Uuid
  page       Int?
  sheet      String?
  row        Int?
  chunkId    String  @map("chunk_id")
  score      Float

  message  Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id])

  @@index([messageId])
  @@index([documentId])
  @@map("message_sources")
}

model AuditLog {
  id       String   @id @default(uuid()) @db.Uuid
  adminId  String   @map("admin_id") @db.Uuid
  action   String
  entity   String
  entityId String?  @map("entity_id")
  payload  Json?
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entity, entityId])
  @@map("audit_log")
}

model DailyStats {
  date          DateTime @id @db.Date
  questions     Int      @default(0)
  refusals      Int      @default(0)
  lowConfidence Int      @default(0) @map("low_confidence")
  tokensIn      Int      @default(0) @map("tokens_in")
  tokensOut     Int      @default(0) @map("tokens_out")
  cacheHits     Int      @default(0) @map("cache_hits")

  @@map("daily_stats")
}
