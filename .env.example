# ─────────────────────────────────────────────────────────────
# Enterprise RAG Assistant — пример переменных окружения
# Скопируйте в .env и заполните секреты. НЕ коммитить реальный .env.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_dev_password
POSTGRES_DB=rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://rag:rag_dev_password@localhost:5432/rag?schema=public

# ── Redis (кэш ответов, sessions, BullMQ) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Qdrant (векторы) ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── S3 / MinIO (оригиналы файлов) ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=rag-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Auth (JWT) ──
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Первый администратор (seed). Меняется после первого входа.
SEED_ADMIN_EMAIL=admin@company.am
SEED_ADMIN_PASSWORD=change_me_admin_password

# ── API ──
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MIN=20

# ── LLM / Embeddings (используются с Фазы 2+; в Фазе 1 не обязательны) ──
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Фаза 0: self-hosted bge-m3 (dim 1024) валидирован и проходит порог (recall@5=0.96),
# OpenAI-эмбеддинги не обязательны. text-embedding-3-large (dim 3072) — если понадобится
# сравнение/переход. При bge-m3 привести размер вектора Qdrant к 1024.
EMBEDDING_MODEL=bge-m3
RERANKER_MODEL=bge-reranker-v2-m3

# ── RAG-параметры (см. docs/02-ARCHITECTURE.md) ──
RERANK_TOP_IN=20
RERANK_TOP_OUT=5
THRESHOLD_LOW=0.35
THRESHOLD_HIGH=0.62
CHAT_HISTORY_MAX_MESSAGES=12
CACHE_TTL_SECONDS=604800

# ── Ingest service (Python FastAPI) ──
INGEST_URL=http://localhost:8000

# ── Web (Next.js) ──
NEXT_PUBLIC_API_URL=http://localhost:4000
